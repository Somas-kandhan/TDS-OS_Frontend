{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tds-os-backend.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://tds-os-backend.onrender.com/uploads/:path*"
    },
    {
      "source": "/health",
      "destination": "https://tds-os-backend.onrender.com/health"
    },
    {
      "source": "/ready",
      "destination": "https://tds-os-backend.onrender.com/ready"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
